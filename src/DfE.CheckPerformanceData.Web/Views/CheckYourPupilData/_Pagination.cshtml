@model DfE.CheckPerformanceData.Web.Controllers.ViewModels.PaginationViewModel

@{
    string PageUrl(int page)
    {
        var pupilsPage = Model.PageParam == "pupilsPage" ? page : Model.OtherPage;
        var resultsPage = Model.PageParam == "resultsPage" ? page : Model.OtherPage;
        return Url.Action("Index", "CheckYourPupilData", new { windowId = Model.WindowId, pupilsPage, resultsPage })! + Model.TabAnchor;
    }
}

@if (Model.TotalPages > 1)
{
    <nav class="govuk-pagination" aria-label="Pagination">
        @if (Model.CurrentPage > 0)
        {
            <div class="govuk-pagination__prev">
                <a class="govuk-link govuk-pagination__link" href="@PageUrl(Model.CurrentPage - 1)" rel="prev">
                    <svg class="govuk-pagination__icon govuk-pagination__icon--prev" xmlns="http://www.w3.org/2000/svg" height="13" width="15" focusable="false" viewBox="0 0 15 13">
                        <path d="m6.5938-0.0078125-6.7266 6.7266 6.7441 6.4062 1.377-1.449-4.1856-3.9768h12.896v-2h-12.984l4.2931-4.293-1.414-1.414z" />
                    </svg>
                    <span class="govuk-pagination__link-title">
                        Previous<span class="govuk-visually-hidden"> page</span>
                    </span>
                </a>
            </div>
        }
        <ul class="govuk-pagination__list">
            @for (var i = 0; i < Model.TotalPages; i++)
            {
                <li class="govuk-pagination__item @(i == Model.CurrentPage ? "govuk-pagination__item--current" : null)">
                    <a class="govuk-link govuk-pagination__link"
                       href="@PageUrl(i)"
                       aria-label="Page @(i + 1)"
                       @(i == Model.CurrentPage ? Html.Raw("aria-current=\"page\"") : null)>
                        @(i + 1)
                    </a>
                </li>
            }
        </ul>
        @if (Model.CurrentPage < Model.TotalPages - 1)
        {
            <div class="govuk-pagination__next">
                <a class="govuk-link govuk-pagination__link" href="@PageUrl(Model.CurrentPage + 1)" rel="next">
                    <span class="govuk-pagination__link-title">
                        Next<span class="govuk-visually-hidden"> page</span>
                    </span>
                    <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" focusable="false" viewBox="0 0 15 13">
                        <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z" />
                    </svg>
                </a>
            </div>
        }
    </nav>
}
