@model DfE.CheckPerformanceData.Web.Controllers.ViewModels.PaginationViewModel

@{
    string PageUrl(int page)
    {
        var includedPage = Model.PageParam == "includedPage" ? page : Model.OtherPage;
        var nonIncludedPage = Model.PageParam == "nonIncludedPage" ? page : Model.OtherPage;
        var activeTab = Model.TabAnchor.TrimStart('#');
        return Url.Action("Index", "CheckYourPupilData", new { windowId = Model.WindowId, includedPage, nonIncludedPage, activeTab, includedSearch = Model.IncludedSearch, nonIncludedSearch = Model.NonIncludedSearch })!;
    }
}

@if (Model.TotalPages > 1)
{
    <govuk-pagination>
        @if (Model.CurrentPage > 0)
        {
            <govuk-pagination-previous href="@PageUrl(Model.CurrentPage - 1)" />
        }
        @for (var i = 0; i < Model.TotalPages; i++)
        {
            <govuk-pagination-item href="@PageUrl(i)" current="@(i == Model.CurrentPage)">@(i + 1)</govuk-pagination-item>
        }
        @if (Model.CurrentPage < Model.TotalPages - 1)
        {
            <govuk-pagination-next href="@PageUrl(Model.CurrentPage + 1)" />
        }
    </govuk-pagination>
}
