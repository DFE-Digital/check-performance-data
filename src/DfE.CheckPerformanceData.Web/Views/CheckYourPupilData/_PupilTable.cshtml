@model IReadOnlyList<DfE.CheckPerformanceData.Web.Controllers.ViewModels.PupilRow>

<table class="govuk-table">
    <thead class="govuk-table__head">
        <tr class="govuk-table__row">
            <th class="govuk-table__header" scope="col">Last name</th>
            <th class="govuk-table__header" scope="col">First name</th>
            <th class="govuk-table__header" scope="col">Sex</th>
            <th class="govuk-table__header" scope="col">Date of birth</th>
            <th class="govuk-table__header" scope="col">Age</th>
            <th class="govuk-table__header" scope="col">First language</th>
        </tr>
    </thead>
    <tbody class="govuk-table__body">
        @foreach (var pupil in Model)
        {
            <tr class="govuk-table__row">
                <td class="govuk-table__cell">@pupil.Surname</td>
                <td class="govuk-table__cell">@pupil.Firstname</td>
                <td class="govuk-table__cell">@pupil.Sex</td>
                <td class="govuk-table__cell">@pupil.DateOfBirth</td>
                <td class="govuk-table__cell">@pupil.Age</td>
                <td class="govuk-table__cell">@pupil.FirstLanguage</td>
            </tr>
        }
    </tbody>
</table>
