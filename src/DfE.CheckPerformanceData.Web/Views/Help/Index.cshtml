@using DfE.CheckPerformanceData.Application.Wiki
@model DfE.CheckPerformanceData.Web.Controllers.ViewModels.HelpViewModel
@{
    ViewData["Title"] = Model.CurrentPage != null ? $"{Model.CurrentPage.Title} - Help" : "Help";

    IEnumerable<(int Id, string Title, int Depth)> FlattenTree(List<WikiPageTreeNodeDto> nodes, int depth)
    {
        foreach (var node in nodes)
        {
            yield return (node.Id, node.Title, depth);
            foreach (var child in FlattenTree(node.Children, depth + 1))
                yield return child;
        }
    }

    var flatPages = FlattenTree(Model.NavigationTree, 0).ToList();
}

<div class="wiki-layout">
    <aside class="wiki-sidebar" id="wiki-sidebar" aria-label="Help pages navigation">
        <nav class="wiki-navigation">
            @await Html.PartialAsync("_WikiSearch", (DfE.CheckPerformanceData.Web.Controllers.ViewModels.SearchResultsViewModel?)null)

            <h2 class="govuk-heading-s">Help pages</h2>

            @if (Model.NavigationTree.Count > 0)
            {
                @await Html.PartialAsync("_WikiTree", Model.NavigationTree, new ViewDataDictionary(ViewData)
                {
                    { "CurrentSlugPath", Model.CurrentSlugPath },
                    { "IsEditMode", Model.IsEditMode }
                })
            }
            else
            {
                <p class="govuk-body govuk-body-s">No pages yet.</p>
            }

            @if (Model.IsEditMode)
            {
                var createError = TempData["WikiCreateError"] as string;
                var attemptedTitle = TempData["WikiCreateAttemptedTitle"] as string;
                var attemptedParentId = TempData["WikiCreateAttemptedParentId"] as int?;
                var hasError = !string.IsNullOrEmpty(createError);

                <details class="govuk-details wiki-add-page-details" data-module="govuk-details" open="@(hasError ? "open" : null)">
                    <summary class="govuk-details__summary">
                        <span class="govuk-details__summary-text">Add new page</span>
                    </summary>
                    <div class="govuk-details__text">
                        @if (hasError)
                        {
                            <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert">
                                <h2 class="govuk-error-summary__title">There is a problem</h2>
                                <div class="govuk-error-summary__body">
                                    <ul class="govuk-list govuk-error-summary__list">
                                        <li><a href="#new-page-title">@createError</a></li>
                                    </ul>
                                </div>
                            </div>
                        }
                        <form asp-controller="Help" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="editMode" value="true" />
                            <div class="govuk-form-group @(hasError ? "govuk-form-group--error" : "")">
                                <label class="govuk-label" for="new-page-title">Page title</label>
                                @if (hasError)
                                {
                                    <p id="new-page-title-error" class="govuk-error-message">
                                        <span class="govuk-visually-hidden">Error:</span> @createError
                                    </p>
                                }
                                <input class="govuk-input govuk-input--width-20 @(hasError ? "govuk-input--error" : "")"
                                       id="new-page-title" name="Title" type="text"
                                       value="@attemptedTitle"
                                       aria-describedby="@(hasError ? "new-page-title-error" : null)"
                                       required>
                            </div>
                            <div class="govuk-form-group">
                                <label class="govuk-label" for="new-page-parent">Parent page (optional)</label>
                                <select class="govuk-select" id="new-page-parent" name="ParentId">
                                    <option value="">None (root level)</option>
                                    @foreach (var item in flatPages)
                                    {
                                        var indent = new string(' ', item.Depth * 2);
                                        var selected = attemptedParentId.HasValue && attemptedParentId.Value == item.Id;
                                        <option value="@item.Id" selected="@(selected ? "selected" : null)">@indent@item.Title</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
                                Add page
                            </button>
                        </form>
                    </div>
                </details>
            }
        </nav>
    </aside>

    <main class="wiki-main">
        <div class="wiki-toolbar">
            <button class="wiki-sidebar-toggle" type="button" id="wiki-sidebar-toggle" aria-expanded="true" aria-controls="wiki-sidebar" title="Toggle navigation">
                <svg class="wiki-sidebar-toggle-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
                    <path d="M9 2L4 7l5 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
            </button>
            <div class="wiki-mode-toggle">
            @if (Model.IsEditMode)
            {
                <a href="/help/@Model.CurrentSlugPath" class="govuk-link wiki-mode-link">
                    <svg class="wiki-mode-icon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
                        <circle cx="8" cy="8" r="2.2" fill="none" stroke="currentColor" stroke-width="1.4"></circle>
                    </svg>
                    <span>View mode</span>
                </a>
                <a href="/help/deleted" class="govuk-link wiki-mode-link">
                    <svg class="wiki-mode-icon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path d="M3 4h10M6 4V2.5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1V4M4.5 4l.5 9a1.5 1.5 0 0 0 1.5 1.5h3A1.5 1.5 0 0 0 11 13l.5-9" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                    <span>Deleted pages</span>
                </a>
            }
            else
            {
                <a href="/help/@(string.IsNullOrEmpty(Model.CurrentSlugPath) ? "?edit" : Model.CurrentSlugPath + "?edit")" class="govuk-link wiki-mode-link">
                    <svg class="wiki-mode-icon" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                        <path d="M11.5 1.5l3 3L5 14l-3.5.5L2 11l9.5-9.5z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
                        <path d="M9.5 3.5l3 3" fill="none" stroke="currentColor" stroke-width="1.4"></path>
                    </svg>
                    <span>Edit mode</span>
                </a>
            }
            </div>
        </div>

        @if (Model.CurrentPage != null)
        {
            @if (Model.IsEditMode)
            {
                @await Html.PartialAsync("_WikiEdit", Model.CurrentPage)
            }
            else
            {
                <h1 class="govuk-heading-l">@Model.CurrentPage.Title</h1>
                <div class="wiki-content govuk-body">
                    @Html.Raw(Model.CurrentPage.ContentHtml)
                </div>
            }
        }
        else
        {
            <h1 class="govuk-heading-l">Help</h1>
            <p class="govuk-body">Welcome to the help section. @(Model.NavigationTree.Count == 0 ? "Switch to edit mode to create the first page." : "Select a page from the navigation.")</p>
        }
    </main>
</div>
