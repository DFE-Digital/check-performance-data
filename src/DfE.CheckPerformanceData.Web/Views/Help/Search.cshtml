@model DfE.CheckPerformanceData.Web.Controllers.ViewModels.SearchResultsViewModel
@using DfE.CheckPerformanceData.Application.Wiki

@{
    string TruncateForDisplay(string s, int max = 120) =>
        s.Length <= max ? s : s.Substring(0, max) + "…";

    string displayQuery = TruncateForDisplay(Model.CurrentQuery ?? string.Empty);

    string heading = Model.InvalidReason is not null
        ? "Search the help pages"
        : Model.TotalCount == 0
            ? $"No results for \"{displayQuery}\""
            : $"Search results for \"{displayQuery}\"";

    ViewData["Title"] = Model.InvalidReason is not null
        ? "Search"
        : Model.TotalCount == 0
            ? $"No results for \"{displayQuery}\""
            : $"Search results for \"{displayQuery}\"";
}

<div class="wiki-layout">
    <aside class="wiki-sidebar" id="wiki-sidebar" aria-label="Help pages navigation">
        <nav class="wiki-navigation">
            @await Html.PartialAsync("_WikiSearch", Model)

            <h2 class="govuk-heading-s">Help pages</h2>

            @if (Model.NavigationTree.Count > 0)
            {
                @await Html.PartialAsync("_WikiTree", Model.NavigationTree, new ViewDataDictionary(ViewData)
                {
                    { "CurrentSlugPath", string.Empty },
                    { "IsEditMode", false }
                })
            }
            else
            {
                <p class="govuk-body govuk-body-s">No pages yet.</p>
            }
        </nav>
    </aside>

    <main class="wiki-main">
        <div class="wiki-toolbar">
            <button class="wiki-sidebar-toggle" type="button" id="wiki-sidebar-toggle" aria-expanded="true" aria-controls="wiki-sidebar" title="Toggle navigation">
                <svg class="wiki-sidebar-toggle-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
                    <path d="M9 2L4 7l5 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
            </button>
        </div>

        <a href="/help" class="govuk-back-link">Back to Help</a>

        <h1 class="govuk-heading-l">@heading</h1>

        @if (Model.ErrorMessages.Count > 0)
        {
            <govuk-error-summary>
                <govuk-error-summary-title>There is a problem</govuk-error-summary-title>
                <govuk-error-summary-item href="#@Model.InputId">@Model.ErrorMessages[0]</govuk-error-summary-item>
            </govuk-error-summary>
        }

        @if (Model.InvalidReason is null && Model.Results.Count > 0)
        {
            <ul class="govuk-list govuk-!-margin-bottom-6">
                @foreach (var r in Model.Results)
                {
                    <li class="govuk-!-margin-bottom-4">
                        <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
                            <a class="govuk-link" href="/help/@r.SlugPath">@r.Title</a>
                        </h2>
                        <p class="govuk-body-s govuk-!-margin-top-0 govuk-!-margin-bottom-2">/help/@r.SlugPath</p>
                        @* Safe unencoded render: SnippetHtml is ts_headline output. BodyPlainText is       *@
                        @* tag-stripped at write time (Plans 02, 03, 05). The only HTML ts_headline can     *@
                        @* emit is mark-tag wrapping of matched terms. See 05-UI-SPEC.md §Security          *@
                        @* Contract + T-XSS-01 in 05-03 threat model. This is the ONE new unencoded call.   *@
                        <p class="govuk-body govuk-!-margin-bottom-0">@Html.Raw(r.SnippetHtml)</p>
                    </li>
                }
            </ul>
        }
        else if (Model.InvalidReason is null && Model.TotalCount == 0)
        {
            <p class="govuk-body">
                Try a different search term, or <a class="govuk-link" href="/help">browse all help pages</a>.
            </p>
        }

        @if (Model.TotalPages > 1)
        {
            <govuk-pagination>
                @if (Model.CurrentPage > 1)
                {
                    <govuk-pagination-previous href="@Url.Action("Search", "Help", new { q = Model.CurrentQuery, page = Model.CurrentPage - 1 })">Previous</govuk-pagination-previous>
                }

                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    var showPage = p == 1
                                   || p == Model.TotalPages
                                   || (p >= Model.CurrentPage - 1 && p <= Model.CurrentPage + 1);
                    if (showPage)
                    {
                        <govuk-pagination-item href="@Url.Action("Search", "Help", new { q = Model.CurrentQuery, page = p })"
                                               current="@(p == Model.CurrentPage)">@p</govuk-pagination-item>
                    }
                    else if (p == 2 || p == Model.TotalPages - 1)
                    {
                        <govuk-pagination-ellipsis></govuk-pagination-ellipsis>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <govuk-pagination-next href="@Url.Action("Search", "Help", new { q = Model.CurrentQuery, page = Model.CurrentPage + 1 })">Next</govuk-pagination-next>
                }
            </govuk-pagination>
        }
    </main>
</div>
