@using DfE.CheckPerformanceData.Application.Wiki
@model List<WikiPageTreeNodeDto>
@{
    var isEditMode = ViewData["IsEditMode"] is true;
    var currentSlugPath = (string)(ViewData["CurrentSlugPath"] ?? string.Empty);
    var editSuffix = isEditMode ? "?edit" : "";
    var depth = ViewData["TreeDepth"] is int d ? d : 0;
    var isRoot = depth == 0;
}

<ul class="tv @(isRoot ? "tv-root" : "")">
    @foreach (var node in Model)
    {
        var isActive = node.SlugPath == currentSlugPath;
        var hasChildren = node.Children.Count > 0;
        var isLast = node == Model.Last();

        <li class="tv-item @(isLast ? "tv-item-last" : "")">
            <div class="tv-row" data-page-id="@node.Id" data-parent-id="@node.ParentId" data-sort="@node.SortOrder" draggable="@(isEditMode ? "true" : "false")">
                @if (hasChildren)
                {
                    <button class="tv-toggle" type="button" aria-expanded="true" aria-label="Toggle @node.Title">
                        <span class="tv-icon tv-icon-minus"></span>
                    </button>
                }
                else
                {
                    <span class="tv-connector"></span>
                }

                <a href="/help/@node.SlugPath@editSuffix" class="tv-link @(isActive ? "tv-link-active" : "") @(hasChildren ? "tv-link-parent" : "")" @(isActive ? "aria-current=page" : "")>@node.Title</a>

                @if (isEditMode)
                {
                    var confirmMsg = System.Text.Json.JsonSerializer.Serialize(
                        $"Delete \"{node.Title}\" and all child pages?");
                    <form action="/help/delete/@node.Id" method="post" class="tv-del-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="editMode" value="true" />
                        <button type="submit" class="tv-del" aria-label="Delete @node.Title"
                                title="Delete this page and all children"
                                onclick="return confirm(@confirmMsg);">
                            <svg class="tv-del-icon" width="13" height="13" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                <path d="M5 6.5l.6 8.5a1.2 1.2 0 0 0 1.2 1.1h2.4a1.2 1.2 0 0 0 1.2-1.1L11 6.5z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
                                <path d="M12.5 5.2l-9-2.4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
                                <path d="M8.9 3.7l.25-.85a.7.7 0 0 0 -.5-.87l-1.6-.43a.7.7 0 0 0 -.87.5l-.25.85" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                    </form>
                }
            </div>

            @if (hasChildren)
            {
                var childViewData = new ViewDataDictionary(ViewData);
                childViewData["TreeDepth"] = depth + 1;
                <ul class="tv tv-children">
                    @await Html.PartialAsync("_WikiTree", node.Children, childViewData)
                </ul>
            }
        </li>
    }
</ul>
