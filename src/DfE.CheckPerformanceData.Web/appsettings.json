{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "PostgreSQL",
        "Args": {
          "connectionString": "Postgres",
          "tableName": "Logs",
          "needAutoCreateTable": true
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
