{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "PostgreSQL",
        "Args": {
          "connectionString": "Postgres",
          "tableName": "Logs",
          "needAutoCreateTable": true
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ZendeskSettings": {
    "Subdomain": "the subdomain",
    "Domain": "the domain",
    "Email": "the email",
    "ApiToken": "[PLACE THESE IN YOUR USER SECRETS]"
  },
  "PollySettings": {
    "MaxRetryAttempts": 3,
    "BaseDelayMilliseconds": 1000,
    "JitterMilliseconds": 500

  }
}
