{
  "runtime": "Net100",
  "defaultVariables": null,
  "documentGenerator": {
    "fromDocument": {
      "url": "https://raw.githubusercontent.com/zendesk/sunshine-conversations-api-spec/refs/heads/master/openapi.yaml",
      "output": null
    }
  },
  "codeGenerators": {
    "openApiToCSharpClient": {
      "className": "{controller}Client",
      "namespace": "DfE.CheckPerformanceData.ZendeskClient",

      "generateClientClasses": true,
      "generateDtoTypes": true,
      "generateOptionalParameters": true,
      "generateSeparateFiles": true,
      "generateContractsOutput": true,
      "output": "ZendeskClient.cs",



      "contractsOutputFilePath": "Models//Models.cs",

      "clientBaseClass": ""
    }
  }
}